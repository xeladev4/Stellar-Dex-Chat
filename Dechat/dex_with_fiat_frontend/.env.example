# Copy this file to .env.local and fill in the values before running the app.

# Soroban-compatible RPC endpoint
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Deployed FiatBridge contract ID
NEXT_PUBLIC_FIAT_BRIDGE_CONTRACT=CAWYXBN4PSVXD7NIYEWVFFIIIEUCC6PUN3IMG3J2WHKDB4NVIISMXBPR

# Native XLM SAC contract ID
NEXT_PUBLIC_XLM_SAC_CONTRACT=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Admin Stellar public key (G...)
NEXT_PUBLIC_ADMIN_PUBLIC_KEY=GBLDNEYP3TGZJQG3QKQXQDQKQXQDQKQXQDQKQXQDQKQXQDQKQXQDQKQXQDQKQXQDQ

# Google Gemini API key for the AI assistant
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Optional comma-separated list of IPs allowed to access sensitive admin APIs
# Example: ADMIN_IP_ALLOWLIST=203.0.113.10,198.51.100.20
ADMIN_IP_ALLOWLIST=

# Development-only bypass for localhost requests (ignored in production)
ADMIN_IP_ALLOWLIST_BYPASS_LOCAL=true

# SERVER-ONLY: Do NOT use the NEXT_PUBLIC_ prefix. This key is proxied via
# /api/ai/chat and never sent to the browser.
GEMINI_API_KEY=your_gemini_api_key_here

# Admin secret for accessing reconciliation and audit log endpoints.
ADMIN_SECRET=your_admin_secret_here

# Sentry DSN for error tracking and monitoring
NEXT_PUBLIC_SENTRY_DSN=
